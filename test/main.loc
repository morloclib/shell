module shell.test (test)

import shell
import root-py

-------------------------------------------------------------------------------
-- Test suite functions

source Py from "shell-test.py"
    ( "testEqual"
    , "testTrue"
    , "testGe"
    , "testNonEmpty"
    , "testContains"
    , "printMsg"
    , "printResult"
    , "cleanDir"
    )

testEqual :: Str -> a -> a -> (Int, Int) -> (Int, Int)
testTrue :: Str -> Bool -> (Int, Int) -> (Int, Int)
testGe :: Str -> a -> a -> (Int, Int) -> (Int, Int)
testNonEmpty :: Str -> Str -> (Int, Int) -> (Int, Int)
testContains :: Str -> [a] -> a -> (Int, Int) -> (Int, Int)
printMsg :: Str -> a -> a
printResult :: (Int, Int) -> (Int, Int)
cleanDir :: Str -> <IO> Unit

testGroup
    :: Str
    -> ((Int, Int) -> <IO> (Int, Int))
    -> (Int, Int)
    -> <IO> (Int, Int)
testGroup msg tests priors = do
  newPriors <- tests priors
  printMsg msg newPriors

passed :: (Int, Int) -> Bool
passed t = 0 == (.0 t)

test = runTests (0,0)

-------------------------------------------------------------------------------
-- Test suite

runTests :: (Int, Int) -> <IO> Bool
runTests s0 = do
  s1 <- testGroup "Path Ops"      testPathOps    s0
  s2 <- testGroup "Navigation"    testNavigation s1
  s3 <- testGroup "File IO"       testFileIO     s2
  s4 <- testGroup "File Info"     testFileInfo   s3
  s5 <- testGroup "Directory Ops" testDirOps     s4
  s6 <- testGroup "Glob"          testGlob       s5
  s7 <- testGroup "Process"       testProcess    s6
  s8 <- testGroup "Environment"   testEnvVars    s7
  s9 <- testGroup "System Info"   testSysInfo    s8
  passed (printResult s9)

-------------------------------------------------------------------------------
-- A. Path operations (pure)

testPathOps :: (Int, Int) -> <IO> (Int, Int)
testPathOps xs = do
  ( testEqual "pathJoin" (pathJoin "/home" "user") "/home/user"
  . testEqual "pathSplit dir" (.0 (pathSplit "/home/user/file.txt")) "/home/user"
  . testEqual "pathSplit file" (.1 (pathSplit "/home/user/file.txt")) "file.txt"
  . testEqual "pathDir" (pathDir "/home/user/file.txt") "/home/user"
  . testEqual "pathBase" (pathBase "/home/user/file.txt") "file.txt"
  . testEqual "pathExt" (pathExt "/home/user/file.txt") ".txt"
  . testEqual "pathStem" (pathStem "/home/user/file.txt") "file"
  . testEqual "replaceExt" (replaceExt "/home/user/file.txt" ".md") "/home/user/file.md"
  . testEqual "addExt" (addExt "/home/user/file" ".txt") "/home/user/file.txt"
  . testEqual "dropExt" (dropExt "/home/user/file.txt") "/home/user/file"
  . testEqual "normPath" (normPath "/home/user/../user/./file.txt") "/home/user/file.txt"
  . testTrue "isAbsolute on absolute" (isAbsolute "/home")
  . testEqual "isAbsolute on relative" (isAbsolute "home") False
  . testTrue "isRelative on relative" (isRelative "home")
  . testEqual "isRelative on absolute" (isRelative "/home") False
  . testEqual "pathComponents" (pathComponents "/home/user/file.txt") ["/", "home", "user", "file.txt"]
  . testEqual "</> operator" ("/home" </> "user") "/home/user"
  . testEqual "<.> operator" ("/home/user/file" <.> ".txt") "/home/user/file.txt"
  ) xs

-------------------------------------------------------------------------------
-- B. Navigation

testNavigation :: (Int, Int) -> <IO> (Int, Int)
testNavigation xs = do
  p <- pwd
  h <- homeDir
  t <- tmpDir
  ( testTrue "pwd is absolute" (isAbsolute p)
  . testNonEmpty "homeDir is non-empty" h
  . testNonEmpty "tmpDir is non-empty" t
  ) xs

-------------------------------------------------------------------------------
-- E. File IO helpers

ioWriteRead :: <IO> Str
ioWriteRead = do
  writeFile "/tmp/morloc_st_wr.txt" "hello"
  x <- readFile "/tmp/morloc_st_wr.txt"
  x

ioAppend :: <IO> Str
ioAppend = do
  writeFile "/tmp/morloc_st_app.txt" "hello"
  appendFile "/tmp/morloc_st_app.txt" " world"
  x <- readFile "/tmp/morloc_st_app.txt"
  x

ioWriteReadLines :: <IO> [Str]
ioWriteReadLines = do
  writeLines "/tmp/morloc_st_wrl.txt" ["alpha", "beta", "gamma"]
  x <- readLines "/tmp/morloc_st_wrl.txt"
  x

ioReadHead :: <IO> [Str]
ioReadHead = do
  writeLines "/tmp/morloc_st_rh.txt" ["a", "b", "c", "d", "e"]
  x <- readHead "/tmp/morloc_st_rh.txt" 2
  x

testFileIO :: (Int, Int) -> <IO> (Int, Int)
testFileIO xs =
  ( testEqual "readHead 2" (!ioReadHead) ["a", "b"]
  . testEqual "writeLines/readLines" (!ioWriteReadLines) ["alpha", "beta", "gamma"]
  . testEqual "appendFile" (!ioAppend) "hello world"
  . testEqual "writeFile/readFile" (!ioWriteRead) "hello"
  ) xs

-------------------------------------------------------------------------------
-- F. File info helpers

ioPathExists :: <IO> Bool
ioPathExists = do
  writeFile "/tmp/morloc_st_pe.txt" "x"
  x <- pathExists "/tmp/morloc_st_pe.txt"
  x

ioIsFileOnFile :: <IO> Bool
ioIsFileOnFile = do
  writeFile "/tmp/morloc_st_if.txt" "x"
  x <- isFile "/tmp/morloc_st_if.txt"
  x

ioFileSize :: <IO> Bytes
ioFileSize = do
  writeFile "/tmp/morloc_st_fs.txt" "hello"
  x <- fileSize "/tmp/morloc_st_fs.txt"
  x

ioStatSize :: <IO> Bytes
ioStatSize = do
  writeFile "/tmp/morloc_st_ss.txt" "hello"
  s <- stat "/tmp/morloc_st_ss.txt"
  .size s

ioStatIsFile :: <IO> Bool
ioStatIsFile = do
  writeFile "/tmp/morloc_st_sif.txt" "hello"
  s <- stat "/tmp/morloc_st_sif.txt"
  .isFile s

testFileInfo :: (Int, Int) -> <IO> (Int, Int)
testFileInfo xs = do
  sif        <- ioStatIsFile
  ssz        <- ioStatSize
  fsz        <- ioFileSize
  iff        <- ioIsFileOnFile
  isFileTmp  <- isFile "/tmp"
  isDirTmp   <- isDir "/tmp"
  isDirFile  <- isDir "/tmp/morloc_st_if.txt"
  peFile     <- ioPathExists
  peMissing  <- pathExists "/tmp/morloc_nonexistent_xyz"
  ( testTrue "stat isFile" sif
  . testEqual "stat size" ssz 5
  . testEqual "fileSize" fsz 5
  . testTrue "isFile on file" iff
  . testEqual "isFile on dir" isFileTmp False
  . testTrue "isDir on dir" isDirTmp
  . testEqual "isDir on file" isDirFile False
  . testTrue "pathExists on file" peFile
  . testEqual "pathExists missing" peMissing False
  ) xs

-------------------------------------------------------------------------------
-- C. Directory ops helpers

ioMkdir :: <IO> Bool
ioMkdir = do
  cleanDir "/tmp/morloc_st_mkdir"
  mkdir "/tmp/morloc_st_mkdir/sub/nested"
  x <- isDir "/tmp/morloc_st_mkdir/sub/nested"
  x

ioLs :: <IO> [Str]
ioLs = do
  cleanDir "/tmp/morloc_st_ls"
  writeFile "/tmp/morloc_st_ls/a.txt" "a"
  writeFile "/tmp/morloc_st_ls/b.txt" "b"
  x <- ls "/tmp/morloc_st_ls"
  x

testDirOps :: (Int, Int) -> <IO> (Int, Int)
testDirOps xs = do
  entries <- ioLs
  mk      <- ioMkdir
  ( testContains "ls contains a.txt" entries "a.txt"
  . testContains "ls contains b.txt" entries "b.txt"
  . testTrue "mkdir creates nested dirs" mk
  ) xs

-------------------------------------------------------------------------------
-- G. Glob helpers

ioGlob :: <IO> [Str]
ioGlob = do
  cleanDir "/tmp/morloc_st_glob"
  writeFile "/tmp/morloc_st_glob/foo.txt" ""
  writeFile "/tmp/morloc_st_glob/bar.txt" ""
  writeFile "/tmp/morloc_st_glob/baz.py" ""
  x <- glob "/tmp/morloc_st_glob/*.txt"
  x

testGlob :: (Int, Int) -> <IO> (Int, Int)
testGlob xs = do
  g <- ioGlob
  ( testEqual "glob *.txt" g ["/tmp/morloc_st_glob/bar.txt", "/tmp/morloc_st_glob/foo.txt"]
  ) xs

-------------------------------------------------------------------------------
-- H. Process helpers

testProcess :: (Int, Int) -> <IO> (Int, Int)
testProcess xs = do
  pid     <- getPid
  cap     <- capture "echo" ["captured"]
  shOut   <- shell "echo hello world"
  runOut  <- run "echo" ["hello"]
  ( testGe "getPid > 0" pid 1
  . testEqual "capture echo" cap "captured\n"
  . testEqual "shell echo stdout" (.stdout shOut) "hello world\n"
  . testEqual "shell echo exitCode" (.exitCode shOut) 0
  . testEqual "run echo stdout" (.stdout runOut) "hello\n"
  . testEqual "run echo exitCode" (.exitCode runOut) 0
  ) xs

-------------------------------------------------------------------------------
-- K. Environment variable helpers

ioSetGetEnv :: <IO> Str
ioSetGetEnv = do
  setEnv "MORLOC_ST_SGET" "test_value_42"
  x <- getEnv "MORLOC_ST_SGET"
  x

ioHasEnvAfterSet :: <IO> Bool
ioHasEnvAfterSet = do
  setEnv "MORLOC_ST_HAS" "yes"
  x <- hasEnv "MORLOC_ST_HAS"
  x

ioHasEnvAfterUnset :: <IO> Bool
ioHasEnvAfterUnset = do
  setEnv "MORLOC_ST_UNSET" "val"
  unsetEnv "MORLOC_ST_UNSET"
  x <- hasEnv "MORLOC_ST_UNSET"
  x

testEnvVars :: (Int, Int) -> <IO> (Int, Int)
testEnvVars xs = do
  unset <- ioHasEnvAfterUnset
  hasV  <- ioHasEnvAfterSet
  val   <- ioSetGetEnv
  ( testEqual "hasEnv after unsetEnv" unset False
  . testTrue "hasEnv after setEnv" hasV
  . testEqual "setEnv/getEnv" val "test_value_42"
  ) xs

-------------------------------------------------------------------------------
-- J. System info

testSysInfo :: (Int, Int) -> <IO> (Int, Int)
testSysInfo xs = do
  c <- cpuCount
  h <- hostname
  o <- uname
  ( testTrue "cpuCount >= 1" (c >= 1)
  . testNonEmpty "hostname non-empty" h
  . testNonEmpty "uname osName non-empty" (.osName o)
  . testNonEmpty "uname machine non-empty" (.machine o)
  ) xs
